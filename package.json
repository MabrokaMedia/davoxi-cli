{
  "name": "@davoxi/cli",
  "version": "0.1.0",
  "description": "CLI tool for the Davoxi AI voice agent platform",
  "author": "Davoxi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
